{
  "version": 2,
  "buildCommand": "npm run vercel-build",
  "installCommand": "npm run vercel-install",
  "outputDirectory": "client/dist",
  "trailingSlash": false,
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/main"
    },
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ]
}
